{
	"name": "hypejunction/elgg_stars",
	"description": "Star rating widget for any Elgg entity — annotate, aggregate, and display.",
	"type": "elgg-plugin",
	"keywords": [
		"elgg",
		"plugin",
		"ratings",
		"stars"
	],
	"license": "GPL-2.0-or-later",
	"authors": [
		{
			"name": "Ismayil Khayredinov",
			"email": "ismayil.khayredinov@gmail.com"
		}
	],
	"require": {
		"php": ">=7.0",
		"composer/installers": "~1.0",
		"elgg/elgg": "^3.0"
	},
	"autoload": {
		"psr-4": {
			"ElggStars\\": "classes/ElggStars/"
		}
	},
	"config": {
		"allow-plugins": {
			"composer/installers": true
		}
	},
	"extra": {
		"elgg-plugin": {
			"id": "elgg_stars"
		}
	}
}
