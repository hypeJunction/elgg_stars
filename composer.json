{
    "name": "hypejunction/elgg_stars",
    "description": "Star rating widget for any Elgg entity \u2014 annotate, aggregate, and display.",
    "type": "elgg-plugin",
    "keywords": [
        "elgg",
        "plugin",
        "ratings",
        "stars"
    ],
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Ismayil Khayredinov",
            "email": "ismayil.khayredinov@gmail.com"
        }
    ],
    "require": {
        "php": ">=7.4",
        "composer/installers": "^2.0",
        "elgg/elgg": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "ElggStars\\": "classes/ElggStars/"
        }
    },
    "config": {
        "allow-plugins": {
            "composer/installers": true
        }
    },
    "extra": {
        "elgg-plugin": {
            "id": "elgg_stars"
        }
    }
}
